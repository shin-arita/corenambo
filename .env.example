TZ=Asia/Tokyo
APP_ENV=local
FRONTEND_PORT=5173
API_PORT=8080
DB_PUBLISH_PORT=5432
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
VITE_API_URL=http://localhost:8080
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=your-secure-password-here
DB_SSLMODE=disable
CORS_ALLOW_ORIGIN=http://localhost:5173

# SMTP（開発環境はSMTP_USER/SMTP_PASS/SMTP_USE_TLSは空でよい）
# 本番環境では必ず設定すること
SMTP_FROM=noreply@example.com
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=false

# JWT（必須・openssl rand -base64 32 で生成した値を設定すること）
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_HOURS=168

COOKIE_SECURE=false
REDIS_ADDR=redis:6379
RATE_LIMIT_IP_PER_MINUTE=5
RATE_LIMIT_EMAIL_PER_5MIN=1
REGISTRATION_TOKEN_EXPIRES_MINUTES=60
REGISTRATION_RESEND_INTERVAL_MINUTES=5
WORKER_STUCK_TIMEOUT_MINUTES=15
WORKER_MAX_RETRY_COUNT=3
